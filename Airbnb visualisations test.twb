      <aliases enabled='yes' />
      <column caption='Proffesional Hosts' datatype='integer' name='[Calculation_0798845246816258]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(CASE [host_listings_count] &gt; 0&#13;&#10;  WHEN [host_listings_count] &gt; 5 THEN [estimated occupancy in the last 365 days]&#13;&#10;END)' />
      </column>
      <column caption='Host type rank' datatype='integer' name='[Calculation_0798845254623237]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN &quot;Professional&quot; THEN RANK(SUM([Estimated Revenue In The Last 365 Days]))&#13;&#10;WHEN &quot;Casual&quot; THEN RANK(SUM([Estimated Revenue In The Last 365 Days]))&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Host Type Drop Down' datatype='string' name='[Calculation_0798845257719814]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Professional&quot; AND [Calculation_0798845254623237] &lt;= 10 THEN &quot;Show&quot;&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &quot;Casual&quot; AND [Calculation_0798845254623237] &gt; 10 THEN &quot;Show&quot;&#13;&#10;ELSE &quot;Hide&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Image URL display' datatype='string' name='[Calculation_0798845281677319]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[picture_url]' />
      </column>
      <column caption='Null dates' datatype='date' name='[Calculation_1614133535940608]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='// Combined Date&#13;&#10;IFNULL(&#13;&#10;    [last checked],&#13;&#10;    [Last Checked]&#13;&#10;)' />
      </column>
      <column caption='Average Price' datatype='real' name='[Calculation_1620730544627714]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(ZN(AVG([price])) &#13;&#10;+ ZN(AVG([price (Cape Town (25 June 2025))])))&#13;&#10;+ ZN(AVG([price (Cape Town (28 Septemeber 2025))]))&#13;&#10;/&#13;&#10;(IIF(ISNULL(AVG([price])), 0, 1) &#13;&#10;+ IIF(ISNULL(AVG([price (Cape Town (25 June 2025))])), 0, 1))&#13;&#10;+ (IIF(ISNULL(AVG([price (Cape Town (28 Septemeber 2025))])), 0, 1))' />
      </column>
      <column caption='Count of Amenities' datatype='integer' name='[Calculation_1949759349211136]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL([amenities]) OR [amenities] = &quot;&quot; THEN 0&#13;&#10;ELSE (LEN([amenities]) - LEN(REPLACE([amenities], &quot;,&quot;, &quot;&quot;))) + 1&#13;&#10;END' />
      </column>
      <column caption='Amenities Drop Down' datatype='boolean' name='[Calculation_1949759352168449]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN &quot;Laundry&quot; THEN CONTAINS([amenities], &quot;laundr&quot;)&#13;&#10;WHEN &quot;Kitchen&quot; THEN CONTAINS([amenities], &quot;Kitchen&quot;)&#13;&#10;WHEN &quot;Hangers&quot; THEN CONTAINS([amenities], &quot;Hangers&quot;)&#13;&#10;WHEN &quot;Dishes&quot; THEN CONTAINS([amenities], &quot;Dishes&quot;)&#13;&#10;WHEN &quot;Iron&quot; THEN CONTAINS([amenities], &quot;Iron&quot;)&#13;&#10;WHEN &quot;Fast wifi 2013 322 Mbps&quot; THEN CONTAINS([amenities], &quot;Fast wifi 2013 322 Mbps&quot;)&#13;&#10;WHEN &quot;Wifi&quot; THEN CONTAINS([amenities], &quot;Wifi&quot;)&#13;&#10;END' />
      </column>
      <column caption='Zero' datatype='integer' name='[Calculation_2321945458577408]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0' />
      </column>
      <column caption='Limit Images' datatype='integer' name='[Calculation_2553941010472960]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INDEX()'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Valid Image' datatype='boolean' name='[Calculation_2553941013176321]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CONTAINS([picture_url], &quot;https://&quot;)  AND (ENDSWITH([picture_url], &quot;.jpg&quot;)  OR  ENDSWITH([picture_url], &quot;.png&quot;)  OR  ENDSWITH([picture_url], &quot;.jpeg&quot;))' />
      </column>
