            <column-instance column='[Calculation_0798845257719814]' derivation='User' name='[usr:Calculation_0798845257719814:nk]' pivot='key' type='nominal'>
              <table-calc ordering-type='Columns' />
              <table-calc field='[federated.0l3i3yd0v4445g18zxl6m0aka5tj].[Calculation_0798845254623237]' ordering-type='Columns' />
