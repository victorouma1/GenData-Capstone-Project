    <worksheet name='Price vs Amenities'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Amenities vs Price</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Cape Town (19 March 2025) (Cape Town (19 March 2025) cleaned)' name='federated.0l3i3yd0v4445g18zxl6m0aka5tj' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Amenities List' datatype='string' name='[Parameter 2]' param-domain-type='list' role='measure' type='nominal' value='&quot;Wifi&quot;'>
              <calculation class='tableau' formula='&quot;Wifi&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0l3i3yd0v4445g18zxl6m0aka5tj'>
            <column caption='Count of Amenities' datatype='integer' name='[Calculation_1949759349211136]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF ISNULL([amenities]) OR [amenities] = &quot;&quot; THEN 0&#13;&#10;ELSE (LEN([amenities]) - LEN(REPLACE([amenities], &quot;,&quot;, &quot;&quot;))) + 1&#13;&#10;END' />
            </column>
            <column caption='Amenities Drop Down' datatype='boolean' name='[Calculation_1949759352168449]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN &quot;Laundry&quot; THEN CONTAINS([amenities], &quot;laundr&quot;)&#13;&#10;WHEN &quot;Kitchen&quot; THEN CONTAINS([amenities], &quot;Kitchen&quot;)&#13;&#10;WHEN &quot;Hangers&quot; THEN CONTAINS([amenities], &quot;Hangers&quot;)&#13;&#10;WHEN &quot;Dishes&quot; THEN CONTAINS([amenities], &quot;Dishes&quot;)&#13;&#10;WHEN &quot;Iron&quot; THEN CONTAINS([amenities], &quot;Iron&quot;)&#13;&#10;WHEN &quot;Fast wifi 2013 322 Mbps&quot; THEN CONTAINS([amenities], &quot;Fast wifi 2013 322 Mbps&quot;)&#13;&#10;WHEN &quot;Wifi&quot; THEN CONTAINS([amenities], &quot;Wifi&quot;)&#13;&#10;END' />
            </column>
            <column caption='Amenities' datatype='string' name='[amenities]' role='dimension' type='nominal' />
            <column-instance column='[price]' derivation='Avg' name='[avg:price:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1949759349211136]' derivation='None' name='[none:Calculation_1949759349211136:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1949759352168449]' derivation='None' name='[none:Calculation_1949759352168449:nk]' pivot='key' type='nominal' />
            <column caption='Price' datatype='real' name='[price]' role='measure' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0l3i3yd0v4445g18zxl6m0aka5tj].[none:Calculation_1949759352168449:nk]'>
            <groupfilter function='member' level='[none:Calculation_1949759352168449:nk]' member='true' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
