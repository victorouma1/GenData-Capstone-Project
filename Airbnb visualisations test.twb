      <manifest manifest-version='0.1'>
        <worksheet-extension extension-version='4.0.4' id='com.infotopics.appsfortableau-extensions.picture-this'>
          <default-locale>en_US</default-locale>
          <name resource-id='name' />
          <description>Infotopics | Apps for tableau extension server, to host the extensions on your
      server.</description>
          <author email='support@appsfortableau.infotopics.com' name='Infotopics | Apps for Tableau' organization='Infotopics | Apps for Tableau' website='https://appsfortableau.infotopics.com' />
          <min-api-version>1.11</min-api-version>
          <source-location>
            <url>https://extensions-appsfortableau.infotopics.com/picture-this-free/</url>
          </source-location>
          <icon></icon>
          <context-menu>
            <configure-context-menu-item />
          </context-menu>
          <encoding id='imageURL'>
            <display-name>Image</display-name>
            <data-spec>
              <data-type>string</data-type>
            </data-spec>
            <role-spec>
              <role-type>discrete-dimension</role-type>
            </role-spec>
            <fields max-count='1' />
            <encoding-icon token='image' />
            <tooltip resource-id='tooltip-x-id'>Image to be displayed</tooltip>
          </encoding>
          <encoding id='displayColumns'>
            <display-name>Data</display-name>
            <encoding-icon token='text' />
            <tooltip resource-id='tooltip-x-id'>Additional columns to be displayed along with the image</tooltip>
          </encoding>
        </worksheet-extension>
        <resources>
          <resource id='name'>
            <text locale='en_US'>PictureThis Free</text>
          </resource>
        </resources>
      </manifest>
      <referenced-views>
        <referenced-view instances='1' viewId='Images' />
