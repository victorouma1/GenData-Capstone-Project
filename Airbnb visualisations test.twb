            <column caption='Price' datatype='real' name='[price]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1620730544627714]' derivation='User' name='[usr:Calculation_1620730544627714:qk]' pivot='key' type='quantitative' />
