      <group caption='Best Casual and Proffesional Hosts' delimiter=',' name='[Set 1]' name-style='unqualified'>
        <groupfilter function='union'>
          <groupfilter field='[Top 10 Casual Hosts]' function='reference' />
          <groupfilter field='[Top 10 Professional Hosts]' function='reference' />
        </groupfilter>
      </group>
      <group caption='Tooltip (Neighbourhood)' hidden='true' name='[Tooltip (Neighbourhood)]' name-style='unqualified' user:auto-column='sheet_link' user:ui-vit-column='true'>
        <groupfilter function='crossjoin'>
          <groupfilter function='level-members' level='[neighbourhood]' />
        </groupfilter>
      </group>
      <group caption='Top 10 Casual Hosts' name='[Top 10 Casual Hosts]' name-style='unqualified' user:ui-builder='filter-group'>
        <groupfilter count='10' end='top' function='end' units='records' user:ui-marker='end'>
          <groupfilter direction='DESC' expression='SUM(CASE [host_listings_count] &gt; 0&#13;&#10;  WHEN [host_listings_count] = 1 THEN [estimated revenue in the last 365 days]&#13;&#10;END)' function='order' user:ui-marker='order'>
            <groupfilter function='level-members' level='[host_id]' user:ui-manual-selection='true' user:ui-manual-selection-all-when-empty='true' user:ui-manual-selection-is-empty='true' user:ui-marker='enumerate' />
          </groupfilter>
        </groupfilter>
